PlayBtn.Visible = false
PlayBtn.Parent = Preview

local PlayCorner = Instance.new("UICorner")
PlayCorner.CornerRadius = UDim.new(0, 8)
PlayCorner.Parent = PlayBtn

-- Data Table
local Games = {
    {Name = "Nuke Your City", ID = "113918641206373", Script = "https://raw.githubusercontent.com/robdipekks-cell/Nuke/refs/heads/main/Nukes"},
    {Name = "Oil Empire", ID = "107095834793267", Script = "https://raw.githubusercontent.com/robdipekks-cell/Oil/refs/heads/main/Oiled"}
}

local currentScript = nil

for _, data in pairs(Games) do
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, -10, 0, 45)
    Btn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    Btn.Text = "  " .. data.Name
    Btn.TextColor3 = Color3.fromRGB(180, 180, 180)
    Btn.Font = Enum.Font.GothamSemibold
    Btn.TextSize = 14
    Btn.TextXAlignment = Enum.TextXAlignment.Left
    Btn.Parent = ListFrame
    
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 8)

    -- Hover Animations
    Btn.MouseEnter:Connect(function()
        TweenService:Create(Btn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(40, 40, 50), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
    end)
    Btn.MouseLeave:Connect(function()
        if currentScript ~= data.Script then
            TweenService:Create(Btn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(30, 30, 35), TextColor3 = Color3.fromRGB(180, 180, 180)}):Play()
        end
    end)

    Btn.MouseButton1Click:Connect(function()
        currentScript = data.Script
        DisplayImg.Image = "rbxthumb://type=Asset&id="..data.ID.."&w=420&h=420"
        PlayBtn.Visible = true
        -- Execution Logic inside PlayBtn below
    end)
end

-- Close & Execute Logic
PlayBtn.MouseButton1Click:Connect(function()
    if currentScript then
        -- Fade Out Animation
        TweenService:Create(MainFrame, TweenInfo.new(0.4), {GroupTransparency = 1, Size = UDim2.new(0, 580, 0, 380)}):Play()
        TweenService:Create(Blur, TweenInfo.new(0.4), {Size = 0}):Play()
        
        task.wait(0.4)
        loadstring(game:HttpGet(currentScript))()
        ScreenGui:Destroy()
        Blur:Destroy()
    end
end)
